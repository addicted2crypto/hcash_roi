# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
CLAUDE.md
AGENTS.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.claude
*/claude
# env files (can opt-in for committing if needed)
.env*
.env.local
.env

# vercel
.vercel

# Backup directory created by scripts/scan-profitability.mjs --full before wiping
data/.backups/

# scan-checkpoint.json IS tracked — daily GitHub Actions cron resumes from it.
# Without committing the checkpoint, every CI run starts from gameStart and
# blows the 30-min runner budget. ~200KB of JSON, acceptable in git.
# profitability-cohorts.json and wallet-pnl.json are also committed — Vercel needs them for display.

# typescript
*.tsbuildinfo
next-env.d.ts
